---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  updated?: string;
}

const { title, updated = "25 June 2026" } = Astro.props;
const pageTitle = `${title} — Magna Cerámica`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="legal-bar">
      <a href="/" class="legal-bar__home" aria-label="Magna Cerámica — home">
        <span class="legal-bar__wordmark">Magna</span>
        <span class="legal-bar__wordmark legal-bar__wordmark--sub">Cerámica</span>
      </a>
      <a href="/" class="legal-bar__back">&#8592; Back to site</a>
    </header>

    <main class="legal container">
      <p class="eyebrow">Legal</p>
      <h1 class="legal__title">{title}</h1>
      <p class="legal__updated">Last updated: {updated}</p>
      <article class="legal__body">
        <slot />
      </article>
    </main>

    <Footer />

    <style>
      .legal-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem var(--gutter);
        border-bottom: 1px solid var(--color-grey);
      }

      .legal-bar__home {
        display: flex;
        flex-direction: column;
        line-height: 1;
        font-family: var(--font-serif);
        color: var(--color-ink);
      }

      .legal-bar__wordmark {
        font-size: 1.4rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .legal-bar__wordmark--sub {
        font-size: 0.7rem;
        letter-spacing: 0.42em;
        color: var(--color-primary);
      }

      .legal-bar__back {
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-muted);
      }

      .legal-bar__back:hover {
        color: var(--color-primary);
      }

      .legal {
        max-width: 820px;
        padding-block: clamp(3rem, 7vw, 5.5rem);
      }

      .legal__title {
        margin-top: 0.5rem;
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: clamp(1.8rem, 4vw, 2.75rem);
      }

      .legal__updated {
        margin-top: 0.5rem;
        color: var(--color-muted);
        font-size: 0.85rem;
      }

      .legal__body {
        margin-top: 2.5rem;
      }

      .legal__body :global(h2) {
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 1.25rem;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
      }

      .legal__body :global(p),
      .legal__body :global(li) {
        color: #3a352f;
        line-height: 1.75;
      }

      .legal__body :global(ul) {
        padding-left: 1.25rem;
      }

      .legal__body :global(li) {
        margin-bottom: 0.4rem;
      }

      .legal__body :global(a) {
        color: var(--color-primary);
        text-decoration: underline;
      }

      .legal__body :global(.cookie-table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.25rem 0 1.5rem;
        font-size: 0.88rem;
      }

      .legal__body :global(.cookie-table th),
      .legal__body :global(.cookie-table td) {
        text-align: left;
        padding: 0.6rem 0.75rem;
        border: 1px solid var(--color-grey);
        vertical-align: top;
      }

      .legal__body :global(.cookie-table th) {
        background: var(--color-cream);
        font-family: var(--font-sans);
        font-weight: 600;
      }

      .legal__body :global(.placeholder) {
        background: #f6e9df;
        color: var(--color-primary-dark);
        padding: 0 0.3em;
        border-radius: 2px;
        font-weight: 600;
      }
    </style>
  </body>
</html>

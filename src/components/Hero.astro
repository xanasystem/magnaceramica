---
// Full-screen hero with background video and centered wordmark
import { Image } from "astro:assets";
import { media } from "../config/media";
import logoWhite from "../assets/logo-magna-white.png";
---

<section class="hero">
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/img/hero-poster.webp"
  >
    <source src={media.headerVideo} type="video/mp4" />
  </video>
  <div class="hero__overlay"></div>

  <header class="hero__bar">
    <Image
      class="hero__logo"
      src={logoWhite}
      width={180}
      height={61}
      alt="Magna Cerámica"
    />
  </header>

  <div class="hero__content">
    <h1 class="hero__title">Trusted Source of Tile</h1>
  </div>

  <a class="hero__scroll" href="#about" aria-label="Scroll to content">
    <span class="hero__scroll-text">Discover more</span>
    <span class="hero__scroll-mouse"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-white);
    overflow: hidden;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(20, 18, 16, 0.45) 0%,
      rgba(20, 18, 16, 0.2) 40%,
      rgba(20, 18, 16, 0.55) 100%
    );
    z-index: -1;
  }

  .hero__bar {
    position: absolute;
    top: clamp(1.5rem, 4vh, 3rem);
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
  }

  .hero__logo {
    width: 180px;
    height: auto;
  }

  .hero__content {
    max-width: 72rem;
    padding-inline: var(--gutter);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.75rem, 8vw, 6.5rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.05;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
  }

  .hero__lead {
    margin-top: 1.25rem;
    font-size: clamp(0.95rem, 1.6vw, 1.2rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.9);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-white);
    text-decoration: none;
  }

  .hero__scroll-text {
    font-size: clamp(0.7rem, 1.2vw, 0.8rem);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
  }

  .hero__scroll-mouse {
    width: 26px;
    height: 42px;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    border-radius: 14px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
  }

  .hero__scroll-mouse::before {
    content: "";
    width: 3px;
    height: 8px;
    border-radius: 2px;
    background: var(--color-white);
    animation: scrollDot 1.8s var(--ease) infinite;
  }

  @keyframes scrollDot {
    0% { opacity: 0; transform: translateY(-4px); }
    40% { opacity: 1; }
    80% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 0; }
  }
</style>

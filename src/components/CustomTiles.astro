---
// Custom / bespoke tile development service
import { Image } from "astro:assets";
import customTiles from "../assets/custom-tiles.webp";
---

<section class="custom section" id="custom">
  <div class="custom__grid container">
    <div class="custom__text">
      <h2 class="section-title custom__title">Custom Made Tiles</h2>
      <p class="custom__sub">Tailored ceramic solutions for unique projects</p>

      <p>
        Magna Cerámica also offers custom-made tile development services,
        connecting clients with specialized manufacturers for bespoke ceramic
        tiles, mosaics, and special pieces.
      </p>
      <p>
        From specific formats and finishes to decorative mosaics or
        made-to-measure ceramic elements, we help bring custom project
        requirements to life through our network of trusted Spanish producers.
      </p>
    </div>

    <figure class="custom__media">
      <Image
        src={customTiles}
        alt="Custom made ceramic tiles and mosaics"
        widths={[700, 1100, 1400, 1800]}
        sizes="(max-width: 768px) 100vw, 50vw"
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>
</section>

<style>
  .custom {
    background: var(--color-grey-light);
    overflow-x: clip;
  }

  .custom__grid {
    display: grid;
    grid-template-columns: 1.15fr 1.2fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .custom__title {
    text-align: left;
  }

  .custom__sub {
    margin-top: 0.75rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: 0.02em;
  }

  .custom__text p:last-child {
    margin-bottom: 0;
  }

  .custom__media {
    margin: 0;
    /* Bleed the image to the right viewport edge (no margin on that side) */
    margin-right: calc(
      -1 * (var(--gutter) + max(0px, (100vw - var(--container)) / 2))
    );
  }

  .custom__media img {
    display: block;
    width: 100%;
    height: clamp(260px, 28vw, 380px);
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .custom__grid {
      grid-template-columns: 1fr;
    }
    .custom__media {
      margin-right: 0;
    }
    .custom__media img {
      height: auto;
      min-height: 0;
      object-fit: contain;
    }
  }
</style>

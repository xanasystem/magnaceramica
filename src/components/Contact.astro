---
// Contact section.
// The form is intentionally left blank for now — it will be embedded later
// via a third-party app. The right column reserves the space.
---

<section class="contact section" id="contact">
  <div class="contact__grid container">
    <div class="contact__intro">
      <h2 class="contact__title">Get in touch</h2>
      <p class="contact__lead">
        Tell us what you're looking for and we'll help you connect with the
        right Spanish tile brands for the UK market.
      </p>

      <h3 class="contact__subhead">Contact info</h3>
      <ul class="contact__details">
        <li>
          <span class="contact__icon" aria-hidden="true">&#9679;</span>
          Avda. Casalduch 55 (12005), Castellón, Spain
        </li>
        <li>
          <span class="contact__icon" aria-hidden="true">&#9679;</span>
          <a href="tel:+34964252250">+34 964 252 250</a>
        </li>
        <li>
          <span class="contact__icon" aria-hidden="true">&#9679;</span>
          <a href="mailto:info@magnaceramica.es">info@magnaceramica.es</a>
        </li>
      </ul>
    </div>

    <!-- Form placeholder: embed the contact form app here later -->
    <div class="contact__form-placeholder" data-form-slot aria-hidden="true"></div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-white);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  .contact__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    color: var(--color-primary);
  }

  .contact__lead {
    margin-top: 1rem;
    max-width: 26rem;
    color: var(--color-muted);
  }

  .contact__subhead {
    margin-top: 2rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.02em;
  }

  .contact__details {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .contact__details li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.95rem;
  }

  .contact__icon {
    color: var(--color-primary);
    font-size: 0.7rem;
  }

  .contact__details a:hover {
    color: var(--color-primary);
  }

  /* Reserves vertical space where the embedded form will go */
  .contact__form-placeholder {
    min-height: clamp(320px, 38vw, 420px);
  }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
    .contact__form-placeholder {
      min-height: 0;
    }
  }
</style>

---
import { Image } from "astro:assets";
import teamPhoto from "../assets/team.webp";
import logoMerhi from "../assets/logo-merhi.png";
import logoMagnaFooter from "../assets/logo-magna-white.png";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__media">
    <Image
      src={teamPhoto}
      alt="The Magna Cerámica team at work"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="lazy"
      decoding="async"
    />
    <div class="footer__media-overlay"></div>
  </div>

  <p class="footer__group">
    Magna Cerámica is the ceramic tile division of
    <Image src={logoMerhi} alt="Grupo Merhi" class="footer__merhi" />
  </p>

  <hr class="footer__divider" />

  <div class="footer__bar">
    <Image
      src={logoMagnaFooter}
      alt="Magna Cerámica"
      widths={[180, 360]}
      sizes="180px"
      class="footer__logo"
    />

    <nav class="footer__legal" aria-label="Legal">
      <a href="/privacy-policy">Privacy Policy</a>
      <span class="footer__sep" aria-hidden="true">|</span>
      <a href="/legal-notice">Legal Notice</a>
      <span class="footer__sep" aria-hidden="true">|</span>
      <a href="/cookies-policy">Cookies Policy</a>
      <span class="footer__sep" aria-hidden="true">|</span>
      <a href="/cookies-policy#preferences" data-cc="show-preferencesModal">Privacy Preferences</a>
    </nav>

    <p class="footer__copy">&copy; {year} Magna Cerámica. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: #000;
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding-bottom: 3rem;
  }

  .footer__media {
    position: relative;
    width: 100%;
    aspect-ratio: 1920 / 332;
    max-height: 332px;
    overflow: hidden;
  }

  .footer__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .footer__media-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }

  .footer__group {
    margin: 0;
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    font-size: clamp(0.95rem, 1.4vw, 1.25rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    color: var(--color-white);
  }

  .footer__merhi {
    height: 30px;
    width: auto;
  }

  .footer__divider {
    width: 100%;
    height: 0;
    margin: 0;
    border: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.25);
  }

  .footer__bar {
    text-align: center;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .footer__logo {
    width: 180px;
    height: auto;
    margin-bottom: 4rem;
  }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.4rem 0.75rem;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.7);
  }

  .footer__legal a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__legal a:hover {
    color: var(--color-white);
  }

  .footer__sep {
    color: rgba(255, 255, 255, 0.35);
  }

  .footer__copy {
    margin: 0;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.4);
  }
</style>

---
import type { Brand } from "../data/brands";

interface Props {
  brand: Brand;
}

const { brand } = Astro.props;
const panelLeft = brand.panel === "left";
---

<article class={`brand ${panelLeft ? "brand--panel-left" : "brand--panel-right"}`}>
  <div class="brand__feature">
    <div class="brand__main">
      <img
        src={brand.main}
        alt={`${brand.name} ceramic tiles`}
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="brand__panel">
      <h3 class="brand__name">{brand.name}</h3>
      <div class="brand__panel-body">
        <p class="brand__desc">{brand.description}</p>
        <a class="brand__visit" href={brand.url} target="_blank" rel="noopener">
          <span>Visit {brand.name}</span>
          <svg class="brand__visit-arrow" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M6.6967 17.3033L17.3033 6.6967M17.5685 14.9168L17.3033 6.6967L9.08318 6.43153"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="square"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="carousel" data-carousel>
    <ul class="carousel__track" data-track>
      {
        brand.carousel.map((src) => {
          const name = src.split("_")[1] ?? brand.name;
          return (
            <li class="carousel__item">
              <img src={src} alt={`${name} — ${brand.name}`} loading="lazy" decoding="async" />
            </li>
          );
        })
      }
    </ul>
    <div class="carousel__dots" aria-label={`${brand.name} gallery navigation`}>
      {
        brand.carousel.map((_, i) => (
          <button class="carousel__dot" data-dot={i} aria-label={`Go to image ${i + 1}`} />
        ))
      }
    </div>
  </div>
</article>

<style>
  .brand {
    --carousel-gap: clamp(0.75rem, 1.4vw, 1.25rem);
    margin-block: clamp(2.5rem, 6vw, 4.5rem);
  }

  .brand__feature {
    display: grid;
    grid-template-columns: 2.6fr 1fr;
    gap: var(--carousel-gap);
    /* Fixed height so every brand block (and its main image) is exactly the
       same height regardless of how long the panel text is. Using `height`
       (not min-/max-height) pins both to 580px. */
    height: 580px;
  }

  .brand--panel-left .brand__feature {
    grid-template-columns: 1fr 2.6fr;
  }

  .brand--panel-left .brand__main {
    order: 2;
  }

  .brand--panel-left .brand__panel {
    order: 1;
  }

  .brand__main {
    overflow: hidden;
  }

  .brand__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand__panel {
    background: var(--color-primary);
    color: var(--color-white);
    padding: clamp(2.25rem, 4vw, 3rem) clamp(1.5rem, 2.6vw, 2.25rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand__panel-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .brand__name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .brand__desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.92);
  }

  .brand__visit {
    align-self: flex-start;
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-white);
    transition: opacity 0.25s var(--ease);
  }

  .brand__visit-arrow {
    width: 1.2em;
    height: 1.2em;
    flex-shrink: 0;
    transition: transform 0.3s var(--ease);
  }

  .brand__visit:hover {
    opacity: 0.85;
  }

  .brand__visit:hover .brand__visit-arrow {
    transform: translate(2px, -2px);
  }

  /* ---- Carousel (right-bleed, horizontal format) ---- */
  .carousel {
    position: relative;
    /* Top space matches the gap between carousel images */
    margin-top: var(--carousel-gap);
  }

  .carousel__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--carousel-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    cursor: grab;
    /* Extend the track to the right viewport edge (no right margin) */
    margin-right: calc(50% - 50vw);
  }

  .carousel__track.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    scroll-snap-type: none;
    user-select: none;
  }

  .carousel__track::-webkit-scrollbar {
    display: none;
  }

  .carousel__item {
    position: relative;
    flex: 0 0 clamp(260px, 30vw, 450px);
    aspect-ratio: 4 / 3;
    scroll-snap-align: start;
    overflow: hidden;
  }

  .carousel__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .carousel__item:hover img {
    transform: scale(1.05);
  }

  /* ---- Pill dots ---- */
  .carousel__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    margin-top: clamp(1rem, 2vw, 1.5rem);
  }

  .carousel__dot {
    width: 6px;
    height: 6px;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: var(--color-grey);
    cursor: pointer;
    transition: width 0.35s var(--ease), background 0.35s var(--ease);
  }

  .carousel__dot:hover {
    background: var(--color-muted);
  }

  .carousel__dot.is-active {
    width: 22px;
    background: rgba(144, 83, 53, 0.6);
  }

  @media (max-width: 768px) {
    .brand__feature,
    .brand--panel-left .brand__feature {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .brand--panel-left .brand__main,
    .brand--panel-left .brand__panel {
      order: initial;
    }

    /* Stacked layout: force both brand images to the same height
       (object-fit crops) instead of each photo's natural ratio. */
    .brand__main {
      aspect-ratio: 3 / 2;
      min-height: 0;
    }
  }
</style>

<script>
  function initBrandCarousels() {
    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
      const track = root.querySelector<HTMLElement>("[data-track]");
      const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
      if (!track || !dots.length) return;

      const step = () => {
        const first = track.querySelector<HTMLElement>(".carousel__item");
        const gap = parseFloat(getComputedStyle(track).columnGap || "0") || 0;
        return first ? first.offsetWidth + gap : 1;
      };

      const setActive = (i: number) => {
        dots.forEach((d, idx) => d.classList.toggle("is-active", idx === i));
      };

      const update = () => {
        const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
        const raw = atEnd ? dots.length - 1 : Math.round(track.scrollLeft / step());
        setActive(Math.max(0, Math.min(dots.length - 1, raw)));
      };

      dots.forEach((d, i) =>
        d.addEventListener("click", () =>
          track.scrollTo({ left: step() * i, behavior: "smooth" })
        )
      );

      let ticking = false;
      track.addEventListener(
        "scroll",
        () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            update();
            ticking = false;
          });
        },
        { passive: true }
      );

      // ---- Drag to scroll ----
      let isDown = false;
      let startX = 0;
      let startScroll = 0;
      let moved = false;

      track.addEventListener("pointerdown", (e) => {
        if (e.button !== 0) return;
        isDown = true;
        moved = false;
        startX = e.clientX;
        startScroll = track.scrollLeft;
        track.classList.add("is-dragging");
        track.setPointerCapture(e.pointerId);
      });

      track.addEventListener("pointermove", (e) => {
        if (!isDown) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 3) moved = true;
        track.scrollLeft = startScroll - dx;
      });

      const endDrag = (e: PointerEvent) => {
        if (!isDown) return;
        isDown = false;
        track.classList.remove("is-dragging");
        try {
          track.releasePointerCapture(e.pointerId);
        } catch {}
      };

      track.addEventListener("pointerup", endDrag);
      track.addEventListener("pointercancel", endDrag);
      // Suppress click navigation right after a drag
      track.addEventListener("click", (e) => {
        if (moved) {
          e.preventDefault();
          e.stopPropagation();
        }
      });
      // Prevent the browser's native image-drag ghost
      track.addEventListener("dragstart", (e) => e.preventDefault());

      update();
    });
  }

  initBrandCarousels();
  document.addEventListener("astro:after-swap", initBrandCarousels);
</script>


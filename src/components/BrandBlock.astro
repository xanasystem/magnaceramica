---
import { Image } from "astro:assets";
import type { Brand } from "../data/brands";

interface Props {
  brand: Brand;
}

const { brand } = Astro.props;
const panelLeft = brand.panel === "left";
---

<article class={`brand ${panelLeft ? "brand--panel-left" : "brand--panel-right"}`}>
  <div class="brand__feature">
    <div class="brand__main">
      <Image
        src={brand.main}
        alt={`${brand.name} ceramic tiles`}
        widths={[760, 1140, 1520, 2000]}
        sizes="(max-width: 768px) 100vw, 62vw"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="brand__panel">
      <h3 class="brand__name">{brand.name}</h3>
      <div class="brand__panel-body">
        <p class="brand__desc">{brand.description}</p>
        <a class="brand__visit" href={brand.url} target="_blank" rel="noopener">
          <span>Visit {brand.name}</span>
          <svg class="brand__visit-arrow" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M6.6967 17.3033L17.3033 6.6967M17.5685 14.9168L17.3033 6.6967L9.08318 6.43153"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="square"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="carousel" data-carousel>
    <ul class="carousel__track" data-track>
      {
        brand.carousel.map((src) => {
          const name = src.src.split("/").pop()?.split("_")[1] ?? brand.name;
          return (
            <li class="carousel__item">
              <Image
                src={src}
                alt={`${name} — ${brand.name}`}
                widths={[400, 600, 900]}
                sizes="(max-width: 768px) 80vw, 450px"
                data-full={src.src}
                loading="lazy"
                decoding="async"
              />
            </li>
          );
        })
      }
    </ul>
    <div class="carousel__dots" aria-label={`${brand.name} gallery navigation`}>
      {
        brand.carousel.map((_, i) => (
          <button class="carousel__dot" data-dot={i} aria-label={`Go to image ${i + 1}`} />
        ))
      }
    </div>
  </div>
</article>

<style>
  .brand {
    --carousel-gap: clamp(0.75rem, 1.4vw, 1.25rem);
    margin-block: clamp(2.5rem, 6vw, 4.5rem);
  }

  /* Wider breathing room between consecutive brand blocks
     (e.g. Baldocer → Alaplana) than at the section's outer edges.
     Uses `~` not `+` because Astro renders a hoisted <script> between the
     two <article> siblings in dev, which would break an adjacent combinator. */
  .brand ~ .brand {
    margin-top: clamp(5rem, 10vw, 8.5rem);
  }

  .brand__feature {
    display: grid;
    grid-template-columns: 2.6fr 1fr;
    gap: var(--carousel-gap);
    /* Fixed height so every brand block (and its main image) is exactly the
       same height regardless of how long the panel text is. Using `height`
       (not min-/max-height) pins both to 580px. */
    height: 580px;
  }

  .brand--panel-left .brand__feature {
    grid-template-columns: 1fr 2.6fr;
  }

  .brand--panel-left .brand__main {
    order: 2;
  }

  .brand--panel-left .brand__panel {
    order: 1;
  }

  .brand__main {
    overflow: hidden;
  }

  .brand__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Ken Burns: continuous zoom + drift on the main image.
       linear timing so it never decelerates to a stop at the extremes. */
    animation: brand-kenburns 10s linear infinite alternate;
    will-change: transform;
  }

  /* Offset the two brands so they don't move in sync. */
  .brand--panel-left .brand__main img {
    animation-delay: -5s;
  }

  @keyframes brand-kenburns {
    from {
      transform: scale(1) translate3d(0, 0, 0);
    }
    to {
      transform: scale(1.18) translate3d(-3%, -2%, 0);
    }
  }

  .brand__panel {
    background: var(--color-primary);
    color: var(--color-white);
    padding: clamp(2.25rem, 4vw, 3rem) clamp(1.5rem, 2.6vw, 2.25rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand__panel-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .brand__name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .brand__desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.92);
  }

  .brand__visit {
    align-self: flex-start;
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-white);
    transition: opacity 0.25s var(--ease);
  }

  .brand__visit-arrow {
    width: 1.2em;
    height: 1.2em;
    flex-shrink: 0;
    transition: transform 0.3s var(--ease);
  }

  .brand__visit:hover {
    opacity: 0.85;
  }

  .brand__visit:hover .brand__visit-arrow {
    transform: translate(2px, -2px);
  }

  /* ---- Carousel (right-bleed, horizontal format) ---- */
  .carousel {
    position: relative;
    /* Top space matches the gap between carousel images */
    margin-top: var(--carousel-gap);
  }

  .carousel__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--carousel-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    cursor: grab;
    /* Extend the track to the right viewport edge (no right margin) */
    margin-right: calc(50% - 50vw);
  }

  .carousel__track.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    scroll-snap-type: none;
    user-select: none;
  }

  .carousel__track::-webkit-scrollbar {
    display: none;
  }

  .carousel__item {
    position: relative;
    flex: 0 0 clamp(260px, 30vw, 450px);
    aspect-ratio: 4 / 3;
    scroll-snap-align: start;
    overflow: hidden;
  }

  .carousel__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: zoom-in;
    transition: transform 0.6s var(--ease);
  }

  .carousel__item:hover img {
    transform: scale(1.05);
  }

  /* ---- Pill dots ---- */
  .carousel__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    margin-top: clamp(1rem, 2vw, 1.5rem);
  }

  .carousel__dot {
    width: 6px;
    height: 6px;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: var(--color-grey);
    cursor: pointer;
    transition: width 0.35s var(--ease), background 0.35s var(--ease);
  }

  .carousel__dot:hover {
    background: var(--color-muted);
  }

  .carousel__dot.is-active {
    width: 22px;
    background: rgba(144, 83, 53, 0.6);
  }

  @media (max-width: 768px) {
    .brand__feature,
    .brand--panel-left .brand__feature {
      grid-template-columns: 1fr;
      /* Stacked: image and panel are separate rows, so the fixed 580px height
         must be released or they overlap. */
      height: auto;
      min-height: 0;
    }

    .brand--panel-left .brand__main,
    .brand--panel-left .brand__panel {
      order: initial;
    }

    /* Stacked layout: force both brand images to the same height
       (object-fit crops) instead of each photo's natural ratio. */
    .brand__main {
      aspect-ratio: 3 / 2;
      min-height: 0;
    }
  }

  /* ---- Lightbox (shared singleton, lives on <body>) ---- */
  :global(.lightbox) {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
    background: rgba(20, 18, 16, 0.92);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s var(--ease), visibility 0.3s var(--ease);
  }

  :global(.lightbox.is-open) {
    opacity: 1;
    visibility: visible;
  }

  :global(.lightbox__img) {
    max-width: min(1100px, 92vw);
    max-height: 88vh;
    width: auto;
    height: auto;
    object-fit: contain;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    transform: scale(0.97);
    transition: transform 0.3s var(--ease);
  }

  :global(.lightbox.is-open .lightbox__img) {
    transform: scale(1);
  }

  :global(.lightbox__close),
  :global(.lightbox__nav) {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-white);
    cursor: pointer;
    line-height: 1;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.25s var(--ease);
  }

  :global(.lightbox__close):hover,
  :global(.lightbox__nav):hover {
    background: rgba(255, 255, 255, 0.25);
  }

  :global(.lightbox__close) {
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    width: 44px;
    height: 44px;
    font-size: 1.5rem;
  }

  :global(.lightbox__nav) {
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    font-size: 2rem;
  }

  :global(.lightbox__nav--prev) {
    left: clamp(0.5rem, 2vw, 1.5rem);
  }

  :global(.lightbox__nav--next) {
    right: clamp(0.5rem, 2vw, 1.5rem);
  }

  @media (max-width: 768px) {
    :global(.lightbox__nav) {
      width: 42px;
      height: 42px;
      font-size: 1.6rem;
    }
  }
</style>

<script>
  type Slide = { src: string; alt: string };
  let openLightbox: ((slides: Slide[], index: number) => void) | null = null;

  function ensureLightbox(): (slides: Slide[], index: number) => void {
    const existing = document.querySelector<HTMLElement>("[data-lightbox]");
    if (openLightbox && existing) return openLightbox;

    const el = document.createElement("div");
    el.className = "lightbox";
    el.setAttribute("data-lightbox", "");
    el.setAttribute("role", "dialog");
    el.setAttribute("aria-modal", "true");
    el.setAttribute("aria-hidden", "true");
    el.innerHTML = `
      <button class="lightbox__nav lightbox__nav--prev" type="button" aria-label="Previous image">&#8249;</button>
      <img class="lightbox__img" alt="" />
      <button class="lightbox__nav lightbox__nav--next" type="button" aria-label="Next image">&#8250;</button>
      <button class="lightbox__close" type="button" aria-label="Close">&#215;</button>`;
    document.body.appendChild(el);

    const img = el.querySelector<HTMLImageElement>(".lightbox__img")!;
    let slides: Slide[] = [];
    let index = 0;

    const render = () => {
      const s = slides[index];
      if (!s) return;
      img.src = s.src;
      img.alt = s.alt;
    };

    const close = () => {
      el.classList.remove("is-open");
      el.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    };

    const go = (dir: number) => {
      if (!slides.length) return;
      index = (index + dir + slides.length) % slides.length;
      render();
    };

    openLightbox = (list, i) => {
      slides = list;
      index = i;
      render();
      el.classList.add("is-open");
      el.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };

    el.querySelector(".lightbox__close")!.addEventListener("click", close);
    el.querySelector(".lightbox__nav--prev")!.addEventListener("click", (e) => {
      e.stopPropagation();
      go(-1);
    });
    el.querySelector(".lightbox__nav--next")!.addEventListener("click", (e) => {
      e.stopPropagation();
      go(1);
    });
    // Click on the backdrop (not the image/buttons) closes
    el.addEventListener("click", (e) => {
      if (e.target === el) close();
    });
    document.addEventListener("keydown", (e) => {
      if (!el.classList.contains("is-open")) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft") go(-1);
      else if (e.key === "ArrowRight") go(1);
    });

    return openLightbox;
  }

  function initBrandCarousels() {
    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
      const track = root.querySelector<HTMLElement>("[data-track]");
      const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
      if (!track || !dots.length) return;

      const step = () => {
        const first = track.querySelector<HTMLElement>(".carousel__item");
        const gap = parseFloat(getComputedStyle(track).columnGap || "0") || 0;
        return first ? first.offsetWidth + gap : 1;
      };

      const setActive = (i: number) => {
        dots.forEach((d, idx) => d.classList.toggle("is-active", idx === i));
      };

      const update = () => {
        const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
        const raw = atEnd ? dots.length - 1 : Math.round(track.scrollLeft / step());
        setActive(Math.max(0, Math.min(dots.length - 1, raw)));
      };

      dots.forEach((d, i) =>
        d.addEventListener("click", () =>
          track.scrollTo({ left: step() * i, behavior: "smooth" })
        )
      );

      let ticking = false;
      track.addEventListener(
        "scroll",
        () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            update();
            ticking = false;
          });
        },
        { passive: true }
      );

      // Images in this carousel, used both for drag-click detection and the
      // lightbox gallery.
      const imgs = Array.from(
        track.querySelectorAll<HTMLImageElement>(".carousel__item img")
      );
      // Lightbox uses the full-resolution original (data-full) rather than the
      // downscaled thumbnail that <Image> renders into the carousel.
      const slides = imgs.map((im) => ({
        src: im.dataset.full || im.src,
        alt: im.alt,
      }));

      // ---- Drag to scroll ----
      let isDown = false;
      let startX = 0;
      let startScroll = 0;
      let moved = false;
      // Index of the image pressed on pointerdown. Tracked here because
      // setPointerCapture redirects the eventual `click` to the track, so we
      // open the lightbox on pointerup instead.
      let pressedIndex = -1;

      track.addEventListener("pointerdown", (e) => {
        if (e.button !== 0) return;
        isDown = true;
        moved = false;
        startX = e.clientX;
        startScroll = track.scrollLeft;
        const img = (e.target as HTMLElement)
          .closest(".carousel__item")
          ?.querySelector("img");
        pressedIndex = img ? imgs.indexOf(img as HTMLImageElement) : -1;
        track.classList.add("is-dragging");
        track.setPointerCapture(e.pointerId);
      });

      track.addEventListener("pointermove", (e) => {
        if (!isDown) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 3) moved = true;
        track.scrollLeft = startScroll - dx;
      });

      const endDrag = (e: PointerEvent) => {
        if (!isDown) return;
        isDown = false;
        track.classList.remove("is-dragging");
        try {
          track.releasePointerCapture(e.pointerId);
        } catch {}
      };

      track.addEventListener("pointerup", (e) => {
        const tapped = !moved && pressedIndex >= 0;
        const i = pressedIndex;
        endDrag(e);
        // A clean tap (no drag) on an image opens it in the lightbox.
        if (tapped) ensureLightbox()(slides, i);
      });
      track.addEventListener("pointercancel", endDrag);
      // Suppress click navigation right after a drag
      track.addEventListener("click", (e) => {
        if (moved) {
          e.preventDefault();
          e.stopPropagation();
        }
      });
      // Prevent the browser's native image-drag ghost
      track.addEventListener("dragstart", (e) => e.preventDefault());

      update();
    });
  }

  initBrandCarousels();
  document.addEventListener("astro:after-swap", initBrandCarousels);
</script>


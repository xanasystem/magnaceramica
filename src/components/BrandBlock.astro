---
import type { Brand } from "../data/brands";

interface Props {
  brand: Brand;
}

const { brand } = Astro.props;
const panelLeft = brand.panel === "left";
---

<article class={`brand ${panelLeft ? "brand--panel-left" : "brand--panel-right"}`}>
  <div class="brand__feature">
    <div class="brand__main">
      <img
        src={brand.main}
        alt={`${brand.name} ceramic tiles`}
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="brand__panel">
      <h3 class="brand__name">{brand.name}</h3>
      <p class="brand__desc">{brand.description}</p>
      <a class="btn btn--ghost" href={brand.url} target="_blank" rel="noopener">
        Visit {brand.name}
      </a>
    </div>
  </div>

  <div class="carousel" data-carousel>
    <button class="carousel__nav carousel__nav--prev" data-prev aria-label="Previous">
      &#8249;
    </button>
    <ul class="carousel__track" data-track>
      {
        brand.carousel.map((src) => {
          const name = src.split("_")[1] ?? brand.name;
          return (
            <li class="carousel__item">
              <img src={src} alt={`${name} — ${brand.name}`} loading="lazy" decoding="async" />
              <span class="carousel__caption">{name}</span>
            </li>
          );
        })
      }
    </ul>
    <button class="carousel__nav carousel__nav--next" data-next aria-label="Next">
      &#8250;
    </button>
  </div>
</article>

<style>
  .brand {
    margin-block: clamp(2.5rem, 6vw, 4.5rem);
  }

  .brand__feature {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    min-height: clamp(360px, 42vw, 560px);
  }

  .brand--panel-left .brand__feature {
    grid-template-columns: 1fr 1.6fr;
  }

  .brand--panel-left .brand__main {
    order: 2;
  }

  .brand--panel-left .brand__panel {
    order: 1;
  }

  .brand__main {
    overflow: hidden;
  }

  .brand__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand__panel {
    background: var(--color-primary);
    color: var(--color-white);
    padding: clamp(2rem, 4vw, 3.5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
  }

  .brand__name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .brand__desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.92);
  }

  .brand__panel .btn--ghost {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  /* ---- Carousel ---- */
  .carousel {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .carousel__track {
    list-style: none;
    margin: 0;
    padding: 0.25rem;
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }

  .carousel__track::-webkit-scrollbar {
    display: none;
  }

  .carousel__item {
    position: relative;
    flex: 0 0 clamp(180px, 24vw, 300px);
    aspect-ratio: 3 / 4;
    scroll-snap-align: start;
    overflow: hidden;
  }

  .carousel__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .carousel__item:hover img {
    transform: scale(1.05);
  }

  .carousel__caption {
    position: absolute;
    left: 0;
    bottom: 0;
    padding: 0.4rem 0.7rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white);
    background: rgba(20, 18, 16, 0.55);
  }

  .carousel__nav {
    flex: 0 0 auto;
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-grey);
    background: var(--color-white);
    color: var(--color-ink);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.25s var(--ease), color 0.25s var(--ease);
  }

  .carousel__nav:hover {
    background: var(--color-primary);
    color: var(--color-white);
    border-color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .brand__feature,
    .brand--panel-left .brand__feature {
      grid-template-columns: 1fr;
    }

    .brand--panel-left .brand__main,
    .brand--panel-left .brand__panel {
      order: initial;
    }

    .brand__main {
      min-height: 240px;
    }

    .carousel__nav {
      display: none;
    }
  }
</style>

<script>
  function initCarousels() {
    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
      const track = root.querySelector<HTMLElement>("[data-track]");
      const prev = root.querySelector<HTMLElement>("[data-prev]");
      const next = root.querySelector<HTMLElement>("[data-next]");
      if (!track) return;

      const step = () => {
        const first = track.querySelector<HTMLElement>(".carousel__item");
        const gap = parseFloat(getComputedStyle(track).columnGap || "12") || 12;
        return first ? first.offsetWidth + gap : track.clientWidth * 0.8;
      };

      prev?.addEventListener("click", () =>
        track.scrollBy({ left: -step() * 2, behavior: "smooth" })
      );
      next?.addEventListener("click", () =>
        track.scrollBy({ left: step() * 2, behavior: "smooth" })
      );
    });
  }

  initCarousels();
  document.addEventListener("astro:after-swap", initCarousels);
</script>

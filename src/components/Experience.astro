---
// Full-width video band — heritage / UK connection statement
import { media } from "../config/media";
---

<section class="experience" id="experience">
  <video
    class="experience__video"
    autoplay
    muted
    loop
    playsinline
    preload="none"
    poster="/img/team.jpg"
  >
    <source src={media.experienceVideo} type="video/mp4" />
  </video>
  <div class="experience__overlay"></div>

  <div class="experience__content container">
    <span class="experience__wordmark">Magna Cerámica</span>
    <h2 class="experience__title">Over 30 Years Connecting Spain and the UK</h2>
    <p class="experience__text">
      For more than three decades, Magna Cerámica has been a pioneer in
      representing Tile of Spain brands in the UK market, building trusted
      relationships between leading Spanish manufacturers and UK clients.
    </p>
  </div>
</section>

<style>
  .experience {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: clamp(420px, 60vh, 620px);
    color: var(--color-white);
    overflow: hidden;
  }

  .experience__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .experience__overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 18, 16, 0.55);
    z-index: -1;
  }

  .experience__content {
    max-width: 48rem;
  }

  .experience__wordmark {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .experience__title {
    margin-top: 1.25rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.25rem, 2.6vw, 2rem);
    letter-spacing: 0.02em;
  }

  .experience__text {
    margin-top: 1.25rem;
    margin-bottom: 0;
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
  }
</style>

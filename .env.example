# Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX).
# Loaded only after the visitor accepts the "Tracking" cookie category.
# Leave empty to keep analytics disabled.
PUBLIC_GA_ID=

# Contact form — recipients (comma-separated for multiple)
FORM_TO=info@magnaceramica.es
FORM_CC=
FORM_BCC=
FORM_SUBJECT=New contact from Magna Cerámica Web

# Contact form — sender (shared verified domain by default; the client's domain
# only on projects with user confirmation)
FORM_FROM_NAME=Magna Cerámica Web
FORM_FROM_EMAIL=no-reply@forms.xanasystem.com

# Contact form — Brevo transactional email API key (one per project, provided by engineering)
BREVO_API_KEY=

# Contact form — Cloudflare Turnstile (anti-bot)
TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=
